{
  "manifest_version": 3,
  "name": "Multichat Stickers",
  "description": "Добавляет кнопку стикеров из мультичата Мисаки в чат YouTube и Twitch",
  "version": "0.1.1",
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.twitch.tv/*"
  ],
  "background": {  
    "service_worker": "background.js"  
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/live_chat*",
        "https://www.youtube.com/watch*",
        "https://www.twitch.tv/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "permissions": [
    "scripting",
    "activeTab"
  ]
}